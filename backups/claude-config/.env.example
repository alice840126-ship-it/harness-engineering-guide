# ~/.claude/.env 파일에 저장할 환경변수
# 실제 값은 ~/.claude/.env에 넣고 절대 깃헙에 올리지 말 것

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
BRAVE_API_KEY=your_brave_api_key
OBSIDIAN_VAULT_PATH=/Users/yourname/Library/Mobile Documents/iCloud~md~obsidian/Documents/your_vault
AGENTS_PATH=/Users/yourname/alice-github/harness-engineering-guide/templates/agents
